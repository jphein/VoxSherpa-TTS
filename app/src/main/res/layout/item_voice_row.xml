<LinearLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
	android:layout_height="70dp"
	android:gravity="center_vertical"
	android:orientation="horizontal"
	android:paddingHorizontal="16dp"
	android:layout_marginHorizontal="8dp"
	android:layout_marginBottom="4dp"
	android:background="@drawable/bg_rounded_bottom"
	android:clickable="true"
	android:focusable="true">
	<ImageView
		android:id="@+id/img_radio_select"
		android:focusable="false"
		android:layout_width="24dp"
		android:layout_height="24dp"
		android:src="@drawable/icon_radio_button_unchecked"
		android:scaleType="fitXY"
		app:tint="#A0AEC0" />
	<LinearLayout
		android:id="@+id/linear2"
		android:layout_width="0dp"
		android:layout_height="wrap_content"
		android:orientation="vertical"
		android:layout_weight="1"
		android:layout_marginStart="16dp">
		<TextView
			android:id="@+id/txt_voice_name"
			android:focusable="false"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:text="Hindi Female 1"
			android:textSize="15sp"
			android:textStyle="bold"
			android:textColor="#FFFFFF" />
		<TextView
			android:id="@+id/txt_voice_desc"
			android:focusable="false"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:layout_marginTop="4dp"
			android:text="Standard Voice • 4.2 MB"
			android:textSize="13sp"
			android:textColor="#A0AEC0" />
	</LinearLayout>
	<com.google.android.material.card.MaterialCardView
		android:id="@+id/btn_play_sample"
		android:layout_width="40dp"
		android:layout_height="40dp"
		app:cardBackgroundColor="#2D2D3F"
		app:cardCornerRadius="20dp"
		app:strokeWidth="0dp"
		android:focusable="true">
		<RelativeLayout
			android:id="@+id/relativelayout2"
			android:layout_width="match_parent"
			android:layout_height="match_parent">
			<ImageView
				android:id="@+id/img_play_icon"
				android:focusable="false"
				android:layout_width="20dp"
				android:layout_height="20dp"
				android:src="@drawable/icon_play_circle"
				android:scaleType="fitXY"
				app:tint="#A0AEC0"
				android:layout_centerInParent="true" />
			<ProgressBar
				android:id="@+id/progress_buffering"
				android:focusable="false"
				android:layout_width="20dp"
				android:layout_height="20dp"
				android:indeterminate="false"
				style="?android:progressBarStyle"
				android:visibility="gone"
				android:layout_centerInParent="true" />
		</RelativeLayout>
	</com.google.android.material.card.MaterialCardView>
</LinearLayout>
