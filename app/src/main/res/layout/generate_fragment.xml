<LinearLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:background="#0B1220"
	android:orientation="vertical"
	android:padding="16dp">
	<RelativeLayout
		android:id="@+id/relativelayout20"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:layout_marginBottom="20dp">
		<ImageView
			android:id="@+id/img_logo"
			android:layout_width="26dp"
			android:layout_height="26dp"
			android:src="@drawable/icon_graphic_eq"
			android:scaleType="fitCenter"
			app:tint="#1D61FF" />
		<TextView
			android:id="@+id/title_tv"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:text="TTS Console"
			android:textSize="20sp"
			android:textStyle="bold"
			android:textColor="#FFFFFF"
			android:layout_marginStart="12dp"
			android:layout_toEndOf="@id/img_logo"
			android:layout_centerVertical="true" />
		<ImageView
			android:id="@+id/save"
			android:layout_width="36dp"
			android:layout_height="36dp"
			android:padding="5dp"
			android:background="?attr/selectableItemBackground"
			android:src="@drawable/icon_save"
			android:scaleType="fitCenter"
			app:tint="#FFFFFF"
			android:layout_alignParentEnd="true"
			android:layout_centerVertical="true" />
	</RelativeLayout>
	<RelativeLayout
		android:id="@+id/relativelayout21"
		android:layout_width="match_parent"
		android:layout_height="wrap_content">
		<TextView
			android:id="@+id/textview55"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:text="INPUT TEXT"
			android:textSize="12sp"
			android:textStyle="bold"
			android:textColor="#566580"
			android:letterSpacing="0.05" />
	</RelativeLayout>
	<com.google.android.material.card.MaterialCardView
		android:id="@+id/cardview26"
		android:layout_width="match_parent"
		android:layout_height="0dp"
		android:layout_marginTop="8dp"
		app:cardBackgroundColor="#131B2D"
		android:layout_weight="1"
		app:cardCornerRadius="16dp"
		app:strokeColor="#1E293B"
		app:strokeWidth="1.5dp"
		app:cardElevation="0dp">
		<FrameLayout
			android:id="@+id/input_relativelayout"
			android:layout_width="match_parent"
			android:layout_height="match_parent"
			android:paddingLeft="12dp"
			android:paddingTop="12dp"
			android:paddingRight="12dp">
			<ScrollView
				android:id="@+id/vscroll4"
				android:layout_width="match_parent"
				android:layout_height="match_parent"
				android:fillViewport="true"
				android:scrollbars="vertical"
				android:fadeScrollbars="false"
				android:overScrollMode="always">
				<EditText
					android:id="@+id/et_input"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:paddingBottom="64dp"
					android:textSize="16sp"
					android:textColor="#FFFFFF"
					android:hint="Write something to convert into audio..."
					android:textColorHint="#3F4B61"
					android:gravity="top|start"
					android:background="@null"
					android:inputType="textMultiLine"
					android:minHeight="100dp"
					android:paddingStart="16dp"
					android:paddingEnd="16dp" />
			</ScrollView>
			<com.google.android.material.card.MaterialCardView
				android:id="@+id/card_add"
				android:layout_width="44dp"
				android:layout_height="44dp"
				android:layout_marginBottom="16dp"
				app:cardBackgroundColor="#1E293B"
				android:layout_gravity="bottom|end"
				android:layout_marginEnd="16dp"
				app:cardCornerRadius="10dp"
				app:strokeWidth="0dp"
				android:focusable="true"
				android:foreground="?attr/selectableItemBackground">
				<ImageView
					android:id="@+id/imageview62"
					android:layout_width="match_parent"
					android:layout_height="match_parent"
					android:padding="10dp"
					android:src="@drawable/icon_note_add"
					android:scaleType="fitCenter"
					app:tint="#FFFFFF" />
			</com.google.android.material.card.MaterialCardView>
		</FrameLayout>
	</com.google.android.material.card.MaterialCardView>
	<TextView
		android:id="@+id/textview67"
		android:layout_width="wrap_content"
		android:layout_height="wrap_content"
		android:layout_marginTop="24dp"
		android:text="ONNX VOICE MODEL"
		android:textSize="12sp"
		android:textStyle="bold"
		android:textColor="#566580" />
	<com.google.android.material.card.MaterialCardView
		android:id="@+id/voice_info_card"
		android:layout_width="match_parent"
		android:layout_height="50dp"
		android:layout_marginTop="10dp"
		app:cardBackgroundColor="#131B2D"
		app:cardCornerRadius="12dp"
		app:strokeColor="#1E293B"
		app:strokeWidth="1.5dp"
		app:cardElevation="0dp">
		<LinearLayout
			android:id="@+id/linear53"
			android:layout_width="match_parent"
			android:layout_height="match_parent"
			android:gravity="center_vertical"
			android:paddingHorizontal="16dp">
			<ImageView
				android:id="@+id/imageview63"
				android:layout_width="24dp"
				android:layout_height="24dp"
				android:src="@drawable/icon_record_voice"
				android:scaleType="fitCenter"
				app:tint="#1D61FF" />
			<TextView
				android:id="@+id/voice_name_tv"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:padding="8dp"
				android:text="No Model selected"
				android:textSize="16sp"
				android:textColor="#FFFFFF"
				android:layout_weight="1" />
			<ImageView
				android:id="@+id/opne_dropdown"
				android:layout_width="40dp"
				android:layout_height="40dp"
				android:padding="8dp"
				android:background="?attr/selectableItemBackground"
				android:src="@drawable/icon_keyboard_arrow"
				android:scaleType="fitCenter"
				app:tint="#566580" />
		</LinearLayout>
	</com.google.android.material.card.MaterialCardView>
	<com.google.android.material.card.MaterialCardView
		android:id="@+id/card_status"
		android:layout_width="match_parent"
		android:layout_height="130dp"
		android:layout_marginTop="20dp"
		app:cardBackgroundColor="#0F172A"
		app:cardCornerRadius="16dp"
		app:strokeColor="#1E293B"
		app:strokeWidth="1.5dp"
		app:cardElevation="0dp">
		<RelativeLayout
			android:id="@+id/relativelayout2"
			android:layout_width="match_parent"
			android:layout_height="match_parent">
			<LinearLayout
				android:id="@+id/layout_idle_state"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:gravity="center_horizontal"
				android:orientation="vertical"
				android:layout_centerInParent="true">
				<ImageView
					android:id="@+id/imageview65"
					android:layout_width="32dp"
					android:layout_height="32dp"
					android:src="@drawable/icon_graphic_eq"
					android:scaleType="fitCenter"
					app:tint="#1D61FF" />
				<ProgressBar
					android:id="@+id/progress_generating"
					android:layout_width="32dp"
					android:layout_height="32dp"
					android:indeterminate="false"
					style="?android:progressBarStyle"
					android:visibility="gone"
					android:indeterminateTint="#1D61FF" />
				<TextView
					android:id="@+id/textview69"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:layout_marginTop="10dp"
					android:text="READY TO SYNTHESIZE"
					android:textSize="12sp"
					android:textStyle="bold"
					android:textColor="#1D61FF"
					android:letterSpacing="0.05" />
			</LinearLayout>
			<RelativeLayout
				android:id="@+id/layout_generated_state"
				android:layout_width="match_parent"
				android:layout_height="match_parent"
				android:padding="16dp"
				android:visibility="gone">
				<ImageView
					android:id="@+id/img_waveform"
					android:layout_width="match_parent"
					android:layout_height="60dp"
					android:layout_marginTop="5dp"
					android:src="@drawable/default_image"
					android:scaleType="fitCenter"
					app:tint="#1D61FF"
					android:layout_centerHorizontal="true"
					android:layout_alignParentTop="true" />
				<View
					android:id="@+id/playhead_line"
					android:layout_width="2dp"
					android:layout_height="60dp"
					android:layout_marginTop="5dp"
					android:background="#FF4B4B"
					android:elevation="2dp"
					android:visibility="gone"
					android:layout_alignParentTop="true"
					android:layout_alignParentStart="true" />
				<TextView
					android:id="@+id/tv_duration"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:text="0:24 seconds"
					android:textSize="13sp"
					android:textColor="#94A3B8"
					android:layout_alignParentBottom="true"
					android:layout_alignParentStart="true" />
				<com.google.android.material.card.MaterialCardView
					android:id="@+id/btn_export"
					android:layout_width="36dp"
					android:layout_height="36dp"
					app:cardBackgroundColor="#1E293B"
					app:cardCornerRadius="8dp"
					app:strokeWidth="0dp"
					android:layout_alignParentBottom="true"
					android:layout_alignParentEnd="true">
					<ImageView
						android:id="@+id/imageview2"
						android:layout_width="match_parent"
						android:layout_height="match_parent"
						android:padding="8dp"
						android:background="?attr/selectableItemBackground"
						android:src="@drawable/icon_ios_share"
						android:scaleType="fitXY"
						app:tint="#FFFFFF" />
				</com.google.android.material.card.MaterialCardView>
			</RelativeLayout>
		</RelativeLayout>
	</com.google.android.material.card.MaterialCardView>
	<com.google.android.material.card.MaterialCardView
		android:id="@+id/btn_generate"
		android:layout_width="match_parent"
		android:layout_height="46dp"
		android:layout_marginTop="24dp"
		android:layout_marginBottom="8dp"
		app:cardBackgroundColor="#1D61FF"
		app:cardCornerRadius="28dp"
		app:cardElevation="4dp"
		app:strokeWidth="0dp"
		android:focusable="true"
		android:foreground="?attr/selectableItemBackground">
		<LinearLayout
			android:id="@+id/linear54"
			android:layout_width="match_parent"
			android:layout_height="match_parent"
			android:gravity="center_horizontal|center_vertical">
			<ImageView
				android:id="@+id/imageview52"
				android:layout_width="25dp"
				android:layout_height="25dp"
				android:padding="2dp"
				android:src="@drawable/icon_play_circle"
				android:scaleType="fitCenter"
				app:tint="#FFFFFF" />
			<TextView
				android:id="@+id/textview92"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:text="Generate &amp; Play"
				android:textSize="18sp"
				android:textStyle="bold"
				android:textColor="#FFFFFF" />
		</LinearLayout>
	</com.google.android.material.card.MaterialCardView>
</LinearLayout>
