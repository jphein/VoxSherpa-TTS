<LinearLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
	android:layout_height="wrap_content"
	android:orientation="vertical">
	<com.google.android.material.card.MaterialCardView
		android:id="@+id/main_cardview"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:layout_marginBottom="16dp"
		app:cardBackgroundColor="#131B2D"
		app:cardCornerRadius="20dp"
		app:strokeColor="#1E293B"
		app:strokeWidth="1dp">
		<RelativeLayout
			android:id="@+id/main_relativelayout"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:padding="12dp">
			<LinearLayout
				android:id="@+id/model_status_linear"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:orientation="vertical"
				android:layout_toStartOf="@id/box_preview_status">
				<LinearLayout
					android:id="@+id/linear11"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:orientation="horizontal">
					<com.google.android.material.card.MaterialCardView
						android:id="@+id/cardview7"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						app:cardBackgroundColor="#2D3748"
						app:cardCornerRadius="6dp">
						<TextView
							android:id="@+id/onnx_tv"
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:text="ONNX"
							android:textSize="10sp"
							android:textStyle="bold"
							android:textColor="#A0AEC0"
							android:focusable="false"
							android:paddingHorizontal="8dp"
							android:paddingVertical="2dp" />
					</com.google.android.material.card.MaterialCardView>
					<com.google.android.material.card.MaterialCardView
						android:id="@+id/cardview8"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						app:cardBackgroundColor="#1C3D33"
						android:layout_marginStart="8dp"
						app:cardCornerRadius="6dp">
						<TextView
							android:id="@+id/json_tv"
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:text="Token"
							android:textSize="10sp"
							android:textStyle="bold"
							android:textColor="#48BB78"
							android:focusable="false"
							android:paddingHorizontal="8dp"
							android:paddingVertical="2dp" />
					</com.google.android.material.card.MaterialCardView>
				</LinearLayout>
				<TextView
					android:id="@+id/txt_model_id"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:layout_marginTop="8dp"
					android:text="hi_IN-rohan-medium"
					android:textSize="16sp"
					android:textStyle="bold"
					android:textColor="#FFFFFF"
					android:focusable="false"
					android:ellipsize="end"
					android:maxLines="2" />
				<TextView
					android:id="@+id/txt_model_sub"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:layout_marginTop="2dp"
					android:text="Model • 24.5 MB"
					android:textSize="12sp"
					android:textColor="#718096"
					android:focusable="false" />
				<ProgressBar
					android:id="@+id/progress_download"
					android:layout_width="200dp"
					android:layout_height="5dp"
					android:layout_marginTop="12dp"
					android:progress="12"
					android:indeterminate="false"
					style="?android:progressBarStyleHorizontal"
					android:focusable="false"
					android:progressDrawable="@drawable/custom_progress_bar" />
				<LinearLayout
					android:id="@+id/linear12"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:layout_marginTop="16dp"
					android:gravity="center_vertical"
					android:orientation="horizontal">
					<com.google.android.material.card.MaterialCardView
						android:id="@+id/btn_use_voice"
						android:layout_width="wrap_content"
						android:layout_height="32dp"
						app:cardBackgroundColor="#1D61FF"
						app:cardCornerRadius="10dp"
						android:focusable="true">
						<TextView
							android:id="@+id/use_remove_tv"
							android:layout_width="wrap_content"
							android:layout_height="match_parent"
							android:gravity="center_horizontal|center_vertical"
							android:text="Use Voice"
							android:textSize="12sp"
							android:textStyle="bold"
							android:textColor="#FFFFFF"
							android:focusable="false"
							android:paddingHorizontal="16dp" />
					</com.google.android.material.card.MaterialCardView>
					<com.google.android.material.card.MaterialCardView
						android:id="@+id/btn_delete"
						android:layout_width="32dp"
						android:layout_height="32dp"
						app:cardBackgroundColor="#1E293B"
						android:layout_marginStart="8dp"
						app:cardCornerRadius="10dp"
						android:focusable="true">
						<ImageView
							android:id="@+id/imageview9"
							android:layout_width="match_parent"
							android:layout_height="match_parent"
							android:padding="8dp"
							android:src="@drawable/icon_delete"
							android:scaleType="fitXY"
							android:focusable="false"
							app:tint="#A0AEC0" />
					</com.google.android.material.card.MaterialCardView>
				</LinearLayout>
			</LinearLayout>
			<com.google.android.material.card.MaterialCardView
				android:id="@+id/box_preview_status"
				android:layout_width="85dp"
				android:layout_height="90dp"
				app:cardBackgroundColor="#0F172A"
				android:layout_marginStart="10dp"
				app:cardCornerRadius="16dp"
				app:strokeWidth="0dp"
				android:focusable="true"
				android:layout_centerInParent="true"
				android:layout_alignParentEnd="true">
				<RelativeLayout
					android:id="@+id/relativelayout6"
					android:layout_width="match_parent"
					android:layout_height="match_parent">
					<ImageView
						android:id="@+id/img_preview_status"
						android:layout_width="28dp"
						android:layout_height="28dp"
						android:src="@drawable/icon_play_circle"
						android:scaleType="fitXY"
						android:focusable="false"
						app:tint="#1D61FF"
						android:layout_centerInParent="true" />
					<ProgressBar
						android:id="@+id/progress_buffering"
						android:focusable="false"
						android:layout_width="28dp"
						android:layout_height="28dp"
						android:indeterminate="false"
						style="?android:progressBarStyle"
						android:visibility="gone"
						android:layout_centerInParent="true" />
					<ImageView
						android:id="@+id/select_iv"
						android:layout_width="18dp"
						android:layout_height="18dp"
						android:layout_margin="8dp"
						android:src="@drawable/icon_check_circle"
						android:scaleType="fitXY"
						android:focusable="false"
						app:tint="#48BB78"
						android:layout_alignParentBottom="true"
						android:layout_alignParentEnd="true" />
				</RelativeLayout>
			</com.google.android.material.card.MaterialCardView>
		</RelativeLayout>
	</com.google.android.material.card.MaterialCardView>
</LinearLayout>
