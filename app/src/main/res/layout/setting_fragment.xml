<androidx.core.widget.NestedScrollView
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:background="#0F141E">
	<LinearLayout
		android:id="@+id/linear29"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:padding="16dp"
		android:orientation="vertical">
		<FrameLayout
			android:id="@+id/relativelayout18"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginBottom="18dp"
			android:gravity="center_horizontal|center_vertical">
			<TextView
				android:id="@+id/title_tv"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:text="App Settings"
				android:textSize="20sp"
				android:textStyle="bold"
				android:textColor="#FFFFFF"
				android:layout_gravity="center_horizontal|center_vertical" />
		</FrameLayout>
		<TextView
			android:id="@+id/textview58"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:text="VOICE SETTINGS"
			android:textSize="12sp"
			android:textStyle="bold"
			android:textColor="#1D61FF"
			android:letterSpacing="0.05" />
		<LinearLayout
			android:id="@+id/audio_pitch_contener"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginTop="20dp"
			android:orientation="vertical">
			<LinearLayout
				android:id="@+id/relativelayout19"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:gravity="center_vertical"
				android:orientation="horizontal">
				<ImageView
					android:id="@+id/icon_pitch"
					android:layout_width="24dp"
					android:layout_height="24dp"
					android:src="@drawable/icon_graphic_eq"
					android:scaleType="fitXY"
					app:tint="#718096" />
				<TextView
					android:id="@+id/textview59"
					android:layout_width="0dp"
					android:layout_height="wrap_content"
					android:text="Pitch"
					android:textSize="16sp"
					android:textColor="#FFFFFF"
					android:layout_weight="1"
					android:layout_marginStart="16dp" />
				<TextView
					android:id="@+id/pitch_tv"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:text="1.0x"
					android:textSize="14sp"
					android:textColor="#718096" />
			</LinearLayout>
			<SeekBar
				android:id="@+id/seekbar_pitch"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginLeft="12dp"
				android:layout_marginTop="12dp"
				android:layout_marginRight="12dp"
				android:progress="50"
				android:progressTint="#1D61FF"
				android:thumbTint="#1D61FF" />
		</LinearLayout>
		<LinearLayout
			android:id="@+id/audio_speed_contener"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginTop="24dp"
			android:orientation="vertical">
			<LinearLayout
				android:id="@+id/relativelayout20"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:gravity="center_vertical"
				android:orientation="horizontal">
				<ImageView
					android:id="@+id/icon_speed"
					android:layout_width="24dp"
					android:layout_height="24dp"
					android:src="@drawable/icon_speed"
					android:scaleType="fitXY"
					app:tint="#718096" />
				<TextView
					android:id="@+id/textview61"
					android:layout_width="0dp"
					android:layout_height="wrap_content"
					android:text="Speed (Rate)"
					android:textSize="16sp"
					android:textColor="#FFFFFF"
					android:layout_weight="1"
					android:layout_marginStart="16dp" />
				<TextView
					android:id="@+id/speed_tv"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:text="1.0x"
					android:textSize="14sp"
					android:textColor="#718096" />
			</LinearLayout>
			<SeekBar
				android:id="@+id/seekbar_speed"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginLeft="12dp"
				android:layout_marginTop="12dp"
				android:layout_marginRight="12dp"
				android:progress="50"
				android:progressTint="#1D61FF"
				android:thumbTint="#1D61FF" />
		</LinearLayout>
		<View
			android:id="@+id/view32"
			android:layout_width="match_parent"
			android:layout_height="1dp"
			android:background="#1E293B"
			android:layout_marginVertical="28dp" />
		<TextView
			android:id="@+id/textview63"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:text="SPEECH SETTINGS"
			android:textSize="12sp"
			android:textStyle="bold"
			android:textColor="#1D61FF" />
		<LinearLayout
			android:id="@+id/Smart_Punctuation_rl"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginTop="20dp"
			android:gravity="center_vertical"
			android:orientation="horizontal">
			<ImageView
				android:id="@+id/icon_Smart_Punctuation"
				android:layout_width="24dp"
				android:layout_height="24dp"
				android:src="@drawable/icon_tune"
				android:scaleType="fitXY"
				app:tint="#718096" />
			<LinearLayout
				android:id="@+id/linear33"
				android:layout_width="0dp"
				android:layout_height="wrap_content"
				android:orientation="vertical"
				android:layout_weight="1"
				android:layout_marginStart="16dp">
				<TextView
					android:id="@+id/tv_Punctuation_title"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:text="Smart Punctuation"
					android:textSize="16sp"
					android:textColor="#FFFFFF" />
				<TextView
					android:id="@+id/tv_Punctuation_desc"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:text="Natural pauses after punctuation"
					android:textSize="12sp"
					android:textColor="#718096" />
			</LinearLayout>
			<Switch
				android:id="@+id/switch_Punctuation"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:textSize="12sp"
				android:checked="true" />
		</LinearLayout>
		<LinearLayout
			android:id="@+id/emotion_tags_rl"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginTop="16dp"
			android:gravity="center_vertical"
			android:orientation="horizontal">
			<ImageView
				android:id="@+id/icon_emotion"
				android:layout_width="24dp"
				android:layout_height="24dp"
				android:src="@drawable/icon_graphic_eq"
				android:scaleType="fitXY"
				app:tint="#718096" />
			<LinearLayout
				android:id="@+id/linear_dynamic"
				android:layout_width="0dp"
				android:layout_height="wrap_content"
				android:orientation="vertical"
				android:layout_weight="1"
				android:layout_marginStart="16dp">
				<TextView
					android:id="@+id/tv_emotion_title"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:text="Emotion Tags"
					android:textSize="16sp"
					android:textColor="#FFFFFF" />
				<TextView
					android:id="@+id/tv_emotion_desc"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:text="tags like [whisper] and [angry]."
					android:textSize="12sp"
					android:textColor="#718096" />
			</LinearLayout>
			<Switch
				android:id="@+id/switch_emotion"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:textSize="12sp" />
		</LinearLayout>
		<View
			android:id="@+id/view35"
			android:layout_width="match_parent"
			android:layout_height="1dp"
			android:background="#1E293B"
			android:layout_marginVertical="28dp" />
		<TextView
			android:id="@+id/textview66"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:text="STORAGE"
			android:textSize="12sp"
			android:textStyle="bold"
			android:textColor="#1D61FF" />
		<LinearLayout
			android:id="@+id/onnx_model_rl"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginTop="20dp"
			android:gravity="center_vertical"
			android:orientation="horizontal">
			<ImageView
				android:id="@+id/icon_storage"
				android:layout_width="24dp"
				android:layout_height="24dp"
				android:src="@drawable/icon_model_selected"
				android:scaleType="fitXY"
				app:tint="#718096" />
			<LinearLayout
				android:id="@+id/linear36"
				android:layout_width="0dp"
				android:layout_height="wrap_content"
				android:orientation="vertical"
				android:layout_weight="1"
				android:layout_marginStart="16dp">
				<TextView
					android:id="@+id/textview67"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:text="ONNX Models Size"
					android:textSize="16sp"
					android:textColor="#FFFFFF" />
				<TextView
					android:id="@+id/textview68"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:text="4 local models imported"
					android:textSize="12sp"
					android:textColor="#718096" />
			</LinearLayout>
			<TextView
				android:id="@+id/totalSizeCountTv"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:text="1.24 GB"
				android:textSize="14sp"
				android:textStyle="bold"
				android:textColor="#FFFFFF" />
		</LinearLayout>
		<com.google.android.material.card.MaterialCardView
			android:id="@+id/clear_civ"
			android:layout_width="match_parent"
			android:layout_height="52dp"
			android:layout_marginTop="24dp"
			app:cardBackgroundColor="@android:color/transparent"
			app:cardCornerRadius="12dp"
			app:strokeColor="#FF4B4B"
			app:strokeWidth="1dp"
			app:cardElevation="0dp">
			<LinearLayout
				android:id="@+id/linear37"
				android:layout_width="match_parent"
				android:layout_height="match_parent"
				android:gravity="center_horizontal|center_vertical"
				android:orientation="horizontal">
				<ImageView
					android:id="@+id/imageview11"
					android:layout_width="20dp"
					android:layout_height="20dp"
					android:src="@drawable/icon_delete"
					android:scaleType="fitXY"
					app:tint="#FF4B4B" />
				<TextView
					android:id="@+id/textview70"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:text="Clear All Cache"
					android:textSize="14sp"
					android:textStyle="bold"
					android:textColor="#FF4B4B"
					android:layout_marginStart="10dp" />
			</LinearLayout>
		</com.google.android.material.card.MaterialCardView>
		<View
			android:id="@+id/view38"
			android:layout_width="match_parent"
			android:layout_height="1dp"
			android:background="#1E293B"
			android:layout_marginVertical="28dp" />
		<TextView
			android:id="@+id/textview71"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:text="ABOUT"
			android:textSize="12sp"
			android:textStyle="bold"
			android:textColor="#1D61FF" />
		<LinearLayout
			android:id="@+id/app_version_rl"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginTop="20dp"
			android:background="?attr/selectableItemBackground"
			android:gravity="center_vertical"
			android:orientation="horizontal"
			android:paddingVertical="8dp">
			<ImageView
				android:id="@+id/icon_info"
				android:layout_width="24dp"
				android:layout_height="24dp"
				android:src="@drawable/ic_info"
				android:scaleType="fitXY"
				app:tint="#718096" />
			<TextView
				android:id="@+id/textview72"
				android:layout_width="0dp"
				android:layout_height="wrap_content"
				android:text="App Version"
				android:textSize="16sp"
				android:textColor="#FFFFFF"
				android:layout_weight="1"
				android:layout_marginStart="16dp" />
			<TextView
				android:id="@+id/textview73"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:text="v2.9-stable"
				android:textSize="14sp"
				android:textColor="#718096" />
		</LinearLayout>
		<LinearLayout
			android:id="@+id/relativelayout24"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginTop="16dp"
			android:background="?attr/selectableItemBackground"
			android:gravity="center_vertical"
			android:orientation="horizontal"
			android:paddingVertical="8dp">
			<ImageView
				android:id="@+id/icon_license"
				android:layout_width="24dp"
				android:layout_height="24dp"
				android:src="@drawable/icon_security"
				android:scaleType="fitXY"
				app:tint="#718096" />
			<TextView
				android:id="@+id/textview74"
				android:layout_width="0dp"
				android:layout_height="wrap_content"
				android:text="Privacy Policy"
				android:textSize="16sp"
				android:textColor="#FFFFFF"
				android:layout_weight="1"
				android:layout_marginStart="16dp" />
			<ImageView
				android:id="@+id/imageview12"
				android:layout_width="20dp"
				android:layout_height="20dp"
				android:src="@drawable/icon_keyboard_arrow_right"
				android:scaleType="fitXY"
				app:tint="#718096" />
		</LinearLayout>
		<LinearLayout
			android:id="@+id/linear2"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginTop="16dp"
			android:background="?attr/selectableItemBackground"
			android:gravity="center_vertical"
			android:orientation="horizontal"
			android:paddingVertical="8dp">
			<ImageView
				android:id="@+id/imageview3"
				android:layout_width="24dp"
				android:layout_height="24dp"
				android:src="@drawable/icon_text_snippet"
				android:scaleType="fitXY"
				app:tint="#718096" />
			<TextView
				android:id="@+id/textview2"
				android:layout_width="0dp"
				android:layout_height="wrap_content"
				android:text="Open Source &amp; Licenses"
				android:textSize="16sp"
				android:textColor="#FFFFFF"
				android:layout_weight="1"
				android:layout_marginStart="16dp" />
			<ImageView
				android:id="@+id/imageview4"
				android:layout_width="20dp"
				android:layout_height="20dp"
				android:src="@drawable/icon_keyboard_arrow_right"
				android:scaleType="fitXY"
				app:tint="#718096" />
		</LinearLayout>
		<LinearLayout
			android:id="@+id/linear4"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginTop="16dp"
			android:background="?attr/selectableItemBackground"
			android:gravity="center_vertical"
			android:orientation="horizontal"
			android:paddingVertical="8dp">
			<ImageView
				android:id="@+id/imageview7"
				android:layout_width="24dp"
				android:layout_height="24dp"
				android:src="@drawable/icon_feedback"
				android:scaleType="fitXY"
				app:tint="#718096" />
			<TextView
				android:id="@+id/textview4"
				android:layout_width="0dp"
				android:layout_height="wrap_content"
				android:text="Send Feedback"
				android:textSize="16sp"
				android:textColor="#FFFFFF"
				android:layout_weight="1"
				android:layout_marginStart="16dp" />
			<ImageView
				android:id="@+id/imageview8"
				android:layout_width="20dp"
				android:layout_height="20dp"
				android:src="@drawable/icon_keyboard_arrow_right"
				android:scaleType="fitXY"
				app:tint="#718096" />
		</LinearLayout>
		<LinearLayout
			android:id="@+id/linear12"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginTop="16dp"
			android:background="?attr/selectableItemBackground"
			android:gravity="center_vertical"
			android:orientation="horizontal"
			android:paddingVertical="8dp">
			<ImageView
				android:id="@+id/imageview13"
				android:layout_width="24dp"
				android:layout_height="24dp"
				android:src="@drawable/icon_settings_suggest"
				android:scaleType="fitXY"
				app:tint="#718096" />
			<TextView
				android:id="@+id/textview6"
				android:layout_width="0dp"
				android:layout_height="wrap_content"
				android:text="Setup System TTS"
				android:textSize="16sp"
				android:textColor="#FFFFFF"
				android:layout_weight="1"
				android:layout_marginStart="16dp" />
			<ImageView
				android:id="@+id/imageview14"
				android:layout_width="20dp"
				android:layout_height="20dp"
				android:src="@drawable/icon_keyboard_arrow_right"
				android:scaleType="fitXY"
				app:tint="#718096" />
		</LinearLayout>
		<LinearLayout
			android:id="@+id/linear3"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginTop="16dp"
			android:background="?attr/selectableItemBackground"
			android:gravity="center_vertical"
			android:orientation="horizontal"
			android:paddingVertical="8dp">
			<ImageView
				android:id="@+id/imageview5"
				android:layout_width="24dp"
				android:layout_height="24dp"
				android:src="@drawable/icon_system_update"
				android:scaleType="fitXY"
				app:tint="#718096" />
			<TextView
				android:id="@+id/textview3"
				android:layout_width="0dp"
				android:layout_height="wrap_content"
				android:text="Check Update"
				android:textSize="16sp"
				android:textColor="#FFFFFF"
				android:layout_weight="1"
				android:layout_marginStart="16dp" />
			<ImageView
				android:id="@+id/imageview6"
				android:layout_width="20dp"
				android:layout_height="20dp"
				android:src="@drawable/icon_keyboard_arrow_right"
				android:scaleType="fitXY"
				app:tint="#718096" />
		</LinearLayout>
	</LinearLayout>
</androidx.core.widget.NestedScrollView>
